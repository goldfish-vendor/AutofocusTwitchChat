{
    "manifest_version": 3,
    "name": "Auto-focus Chat for Twitch",
    "version": "1.0.0",
    "description": "Auto-focus Twitch chat input when clicking outside the video.",
    "icons": {
        "16": "src/icons/icon16.png",
        "48": "src/icons/icon48.png",
        "128": "src/icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": ["*://*.twitch.tv/*"],
            "js": ["src/content.js"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "Auto-focus Chat for Twitch",
        "default_icon": {
            "16": "src/icons/icon16.png",
            "48": "src/icons/icon48.png"
        }
    }
}